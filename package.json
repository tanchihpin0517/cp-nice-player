{
  "name": "cp-nice-player",
  "displayName": "cp-nice-player",
  "description": "CP's nice player",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cp-nice-player.open"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cp-nice-player.open",
        "title": "Open in CP Nice Player",
        "category": "CP Nice Player"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "cp-nice-player.open",
          "group": "navigation",
          "when": "resourceScheme == file && resourceExtname =~ /\\.(mp3|wav|ogg|flac|m4a|aac|mp4|webm|mov|mkv)$/i"
        }
      ]
    },
    "configuration": {
      "title": "CP Nice Player",
      "properties": {
        "cp-nice-player.ffmpegPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ffmpeg executable. Leave empty to use ffmpeg from PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
